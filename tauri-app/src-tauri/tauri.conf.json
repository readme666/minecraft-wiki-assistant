{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MineRAG",
  "version": "1.0.0",
  "identifier": "com.minecraft.wiki.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "security": {
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "title": "MineRAG",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ]
  }
}
