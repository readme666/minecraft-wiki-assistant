{
  "identifier": "default",
  "description": "default permissions",
  "windows": ["main"],
  "permissions": [
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "core:path:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPDATA/MinecraftWikiAssistant/logs" },
        { "path": "$APPDATA/MinecraftWikiAssistant/logs/**" },
        { "path": "$APPDATA\\MinecraftWikiAssistant\\logs" },
        { "path": "$APPDATA\\MinecraftWikiAssistant\\logs\\**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA\\**" },
        { "path": "$APPDATA/com.minecraft.wiki.assistant/logs" },
        { "path": "$APPDATA/com.minecraft.wiki.assistant/logs/**" },
        { "path": "$APPDATA\\com.minecraft.wiki.assistant\\logs" },
        { "path": "$APPDATA\\com.minecraft.wiki.assistant\\logs\\**" },
        { "path": "$APPDATA/com.minecraft.wiki.assistant/**" }
      ]
    },
    "shell:allow-open",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "http://*/*" }, { "url": "https://*/*" }]
    },
    "opener:default"
  ]
}